meta {
  name: Divide by Zero
  type: http
  seq: 6
}

post {
  url: {{base_url}}/calculate
  body: json
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "a": 10,
    "b": 0,
    "operation": "divide"
  }
}

tests {
  test("should return 400", function() {
    expect(res.status).to.equal(400);
  });

  test("error should mention division by zero", function() {
    expect(res.body.error).to.equal("division by zero");
  });
}
