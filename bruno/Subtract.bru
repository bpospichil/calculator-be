meta {
  name: Subtract
  type: http
  seq: 3
}

post {
  url: {{base_url}}/calculate
  body: json
}

headers {
  Content-Type: application/json
}

body:json {
  {
    "a": 10,
    "b": 3,
    "operation": "subtract"
  }
}

tests {
  test("should return 200", function() {
    expect(res.status).to.equal(200);
  });

  test("result should be 7", function() {
    expect(res.body.result).to.equal(7);
  });
}
